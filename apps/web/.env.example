NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-local-or-project-anon-key

# Auth mode:
# - local-bypass keeps local development fast and uses PFP_SUPABASE_USER_ID as the active user.
# - required should be used in Vercel/production with Supabase Google login enabled.
PFP_AUTH_MODE=local-bypass
PFP_ALLOWED_EMAILS=pavel.vabrousek@gmail.com
PFP_LOCAL_USER_EMAIL=pavel.vabrousek@gmail.com

# Server-only. Required only if using Supabase REST helpers with privileged writes.
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Server-only connection used by the dashboard and market-data updater.
PFP_SUPABASE_DATABASE_URL=postgresql://postgres.project-ref:password@pooler-host:5432/postgres
PFP_SUPABASE_USER_ID=replace-with-auth-user-uuid
PFP_PORTFOLIO_NAME=Google Portfolio Import
PFP_BASE_CURRENCY=CZK
